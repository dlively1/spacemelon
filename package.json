{
  "name": "spacemelon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pixel-art space shooter where you blast watermelons through themed cosmic worlds.",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:install": "playwright install --with-deps chromium",
    "agent:loop": "playwright test --reporter=line"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
