{
  "name": "spacemelon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pixel-art space shooter where you blast watermelons through themed cosmic worlds.",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:install": "playwright install --with-deps chromium",
    "agent:loop": "playwright test --reporter=line"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^25.9.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
